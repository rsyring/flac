[build-system]
requires = ['setuptools>=61']
build-backend = 'setuptools.build_meta'


[project]
name = '{{ project_name }}'
version = '0.1.0'
requires-python = '>=3.12'
dependencies = []


[project.scripts]
'{{ script_name }}' = '{{ py_module }}.cli:main'


[tool.setuptools]
package-dir = {'' = 'src'}


[tool.setuptools.packages.find]
where = ['src']
